# RemoteSudoTouch Linux client configuration
#
# The local port that the reverse SSH tunnel exposes on Ubuntu.
REMOTE_SUDO_TOUCH_PORT=9876
# Timeout while opening the local forwarded socket.
REMOTE_SUDO_TOUCH_CONNECT_TIMEOUT=2
# Timeout while waiting for the Mac-side approval response.
REMOTE_SUDO_TOUCH_RESPONSE_TIMEOUT=15
# Clear stale sshd reverse-forward listeners on timeout and retry once.
REMOTE_SUDO_TOUCH_SELF_HEAL=1
